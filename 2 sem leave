<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Standalone Leave Manager</title>
    <style>
        * { box-sizing: border-box; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        body { background-color: #f0f2f5; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .app-container { background: white; padding: 40px; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); width: 100%; max-width: 450px; }
        h2 { text-align: center; color: #2c3e50; margin-top: 0; margin-bottom: 30px; }
        label { font-weight: bold; color: #34495e; display: block; margin-bottom: 8px; margin-top: 20px; }
        select, input[type="date"] { width: 100%; padding: 12px; border: 2px solid #bdc3c7; border-radius: 6px; font-size: 1rem; outline: none; transition: border-color 0.3s; }
        select:focus, input[type="date"]:focus { border-color: #3498db; }
        
        .date-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        
        button { width: 100%; padding: 15px; margin-top: 30px; background-color: #f39c12; color: white; border: none; border-radius: 6px; font-size: 1.1rem; font-weight: bold; cursor: pointer; transition: background 0.3s; }
        button:hover { background-color: #e67e22; }
        button:disabled { background-color: #95a5a6; cursor: not-allowed; }
        
        #status-message { text-align: center; margin-top: 20px; font-weight: bold; padding: 10px; border-radius: 6px; display: none; }
        .success { background-color: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
        .error { background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
        .warning { background-color: #fff3cd; color: #856404; border: 1px solid #ffeeba; }
        
        #loader { text-align: center; color: #7f8c8d; font-style: italic; margin-bottom: 20px; }
    </style>
</head>
<body>

    <div class="app-container">
        <h2>Leave Management</h2>
        
        <div id="loader">🔄 Connecting to Database...</div>

        <form id="leave-form" style="display: none;">
            <label for="student-select">1. Select Student</label>
            <select id="student-select" required>
                <option value="" disabled selected>Choose a student...</option>
            </select>

            <div class="date-grid">
                <div>
                    <label for="start-date">2. Start Date</label>
                    <input type="date" id="start-date" required>
                </div>
                <div>
                    <label for="end-date">3. End Date</label>
                    <input type="date" id="end-date" required>
                </div>
            </div>

            <button type="submit" id="submit-btn">Register Leave</button>
        </form>

        <div id="status-message"></div>
    </div>

    <script>
        // ==========================================
        // PASTE YOUR GOOGLE APPS SCRIPT URL BELOW
        // ==========================================
        const SCRIPT_URL = "https://script.google.com/macros/s/AKfycbwPah81IfMTIY4ST_A8djsJcua_ahOIzi4T_d7r8mhuFdaHXJaqIq6Ke4aUWg6HCB_A/exec";

        const form = document.getElementById('leave-form');
        const studentSelect = document.getElementById('student-select');
        const loader = document.getElementById('loader');
        const submitBtn = document.getElementById('submit-btn');
        const statusMsg = document.getElementById('status-message');

        let studentDataMap = {}; 

        async function fetchStudents() {
            try {
                const response = await fetch(SCRIPT_URL, {
                    method: 'POST',
                    headers: { 'Content-Type': 'text/plain;charset=utf-8' },
                    body: JSON.stringify({ action: "getStudents" })
                });
                const result = await response.json();

                if (result.status === 'success') {
                    result.students.forEach(student => {
                        const option = document.createElement('option');
                        option.value = student.enrollment; 
                        option.textContent = `${student.name} (${student.enrollment})`;
                        studentSelect.appendChild(option);
                        studentDataMap[student.enrollment] = student;
                    });
                    
                    loader.style.display = 'none';
                    form.style.display = 'block';
                } else {
                    loader.innerText = "❌ Failed to load students. Check Google Sheet.";
                    loader.style.color = "red";
                }
            } catch (err) {
                loader.innerText = "❌ Network Error. Make sure SCRIPT_URL is correct.";
                loader.style.color = "red";
            }
        }

        form.addEventListener('submit', (e) => {
            e.preventDefault(); 
            processLeaveRequest(false);
        });

        async function processLeaveRequest(overridePresentFlag) {
            const enrollment = studentSelect.value;
            const startDate = document.getElementById('start-date').value;
            const endDate = document.getElementById('end-date').value;

            if (new Date(endDate) < new Date(startDate)) {
                showStatus("Error: End Date cannot be before Start Date.", 'error');
                return;
            }

            submitBtn.innerText = "Processing...";
            submitBtn.disabled = true;
            statusMsg.style.display = 'none';

            const payload = {
                action: "submitLeave",
                enrollment: enrollment,
                name: studentDataMap[enrollment].name,
                batch: studentDataMap[enrollment].batch,
                startDate: startDate,
                endDate: endDate,
                overridePresent: overridePresentFlag 
            };

            try {
                const response = await fetch(SCRIPT_URL, {
                    method: 'POST',
                    headers: { 'Content-Type': 'text/plain;charset=utf-8' },
                    body: JSON.stringify(payload)
                });
                const result = await response.json();

                if (result.status === 'success') {
                    showStatus(result.message, 'success');
                    form.reset(); 
                } 
                else if (result.status === 'error') {
                    alert(result.message);
                    showStatus(result.message, 'error');
                }
                else if (result.status === 'confirm') {
                    const userSaidYes = confirm(result.message);
                    
                    if (userSaidYes) {
                        processLeaveRequest(true);
                        return; 
                    } else {
                        showStatus("Leave overwrite cancelled. Record remains unchanged.", 'warning');
                    }
                }
            } catch (err) {
                showStatus("Network Error. Could not connect to Google.", 'error');
            } finally {
                submitBtn.innerText = "Register Leave";
                submitBtn.disabled = false;
            }
        }

        function showStatus(text, type) {
            statusMsg.textContent = text;
            statusMsg.className = type;
            statusMsg.style.display = 'block';
        }

        fetchStudents();
    </script>
</body>
</html>
